<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <EnableDefaultContentItems>true</EnableDefaultContentItems>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <Target Name="Tailwind" BeforeTargets="Build;Publish">
  <Exec Command="npm run build:css" CodeTask="true" FailOnError="true" />
  </Target>

  <Target Name="IncludeGeneratedAllAssets" AfterTargets="Tailwind" BeforeTargets="ComputeFilesToPublish">
    <ItemGroup>
      <Content Include="wwwroot\**" Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)" />
    </ItemGroup>
  </Target>

</Project>